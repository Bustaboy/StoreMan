# Application
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=ndts_wms
POSTGRES_USER=ndts
POSTGRES_PASSWORD=ndts

# Use pgbouncer service name for app connections
DATABASE_URL=postgresql+asyncpg://ndts:ndts@pgbouncer:5432/ndts_wms
SYNC_DATABASE_URL=postgresql://ndts:ndts@pgbouncer:5432/ndts_wms

# Redis (API cache + Celery broker/backend)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Meilisearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me
