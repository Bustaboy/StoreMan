# Application
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=titanwms
POSTGRES_USER=titanwms
POSTGRES_PASSWORD=titanwms

# Use pgbouncer service name for app connections
DATABASE_URL=postgresql+asyncpg://titanwms:titanwms@pgbouncer:5432/titanwms
SYNC_DATABASE_URL=postgresql://titanwms:titanwms@pgbouncer:5432/titanwms

# Redis (API cache + Celery broker/backend)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Meilisearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me
